{
  "name": "psychosoftware",
  "version": "1.0.0",
  "type": "module",
  "main": "assets/script/BackEnd/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.psychosoftware.app",
    "productName": "PsychoSoftWare",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/img/logoPsychoSoftWare.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/img/logoPsychoSoftWare.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
